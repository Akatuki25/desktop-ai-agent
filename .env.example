# Copy to .env and fill in. .env is gitignored.

# ---- secrets ----
DEEPGRAM_API_KEY=

# ---- runtime options ----
AGENT_LOG_LEVEL=INFO

# Override llama-server URL to point at an externally-managed instance.
# Leave empty to let the daemon spawn and manage llama-server itself.
# LLAMA_SERVER_URL=http://127.0.0.1:8080

# Pick which size of Qwen3.5 to run. activate.ps1 / activate.sh will
# use this to select the right GGUF when both 9B and 4B are present
# in models/.
# Values: "9B" (default, ~5.4GB) or "4B" (lighter, ~2.4GB).
# Switch to 4B if 9B is too heavy for your machine and you've already
# downloaded both via setup.ps1 -Model 4B.
# MODEL_SIZE=4B

# Hard override: explicit GGUF path. Wins over MODEL_SIZE.
# LLAMA_MODEL=
