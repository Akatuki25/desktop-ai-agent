# Copy to .env and fill in. .env is gitignored.

# ---- secrets ----
DEEPGRAM_API_KEY=

# ---- runtime options ----
AGENT_LOG_LEVEL=INFO

# Override llama-server URL to point at an externally-managed instance.
# Leave empty to let the daemon spawn and manage llama-server itself.
# LLAMA_SERVER_URL=http://127.0.0.1:8080

# Override model path. Leave empty to use the repo-local default
# resolved by scripts/activate.ps1 (models/Qwen3-8B-Instruct-Q4_K_M.gguf).
# LLAMA_MODEL=
